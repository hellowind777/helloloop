{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "summary",
    "workflow",
    "constraints",
    "requestInterpretation",
    "repoDecision",
    "tasks"
  ],
  "properties": {
    "project": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currentState",
        "implemented",
        "remaining",
        "nextAction"
      ],
      "properties": {
        "currentState": {
          "type": "string",
          "minLength": 1
        },
        "implemented": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "remaining": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nextAction": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currentFocus",
        "mainlineSummary",
        "phaseOrder",
        "parallelLanes",
        "coordinationRules"
      ],
      "properties": {
        "currentFocus": {
          "type": "string",
          "minLength": 1
        },
        "mainlineSummary": {
          "type": "string",
          "minLength": 1
        },
        "phaseOrder": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "product",
              "architecture",
              "contract",
              "implementation",
              "test",
              "review",
              "release",
              "operate"
            ]
          }
        },
        "parallelLanes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "coordinationRules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "constraints": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "requestInterpretation": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "summary",
        "priorities",
        "cautions"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "priorities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cautions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "repoDecision": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "compatibility",
        "action",
        "reason"
      ],
      "properties": {
        "compatibility": {
          "type": "string",
          "enum": [
            "compatible",
            "conflict",
            "uncertain"
          ]
        },
        "action": {
          "type": "string",
          "enum": [
            "continue_existing",
            "confirm_rebuild",
            "start_new"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status",
          "priority",
          "risk",
          "stage",
          "role",
          "lane",
          "parallelGroup",
          "goal",
          "docs",
          "paths",
          "artifacts",
          "blockedBy",
          "acceptance",
          "dependsOn",
          "verify"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "done",
              "blocked"
            ]
          },
          "priority": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "stage": {
            "type": "string",
            "enum": [
              "product",
              "architecture",
              "contract",
              "implementation",
              "test",
              "review",
              "release",
              "operate"
            ]
          },
          "role": {
            "type": "string",
            "enum": [
              "product_owner",
              "architect",
              "summary",
              "control",
              "ux_designer",
              "developer",
              "tester",
              "reviewer",
              "supervisor",
              "release_manager"
            ]
          },
          "lane": {
            "type": "string",
            "minLength": 1
          },
          "parallelGroup": {
            "type": [
              "string",
              "null"
            ]
          },
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "docs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blockedBy": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "type",
                "id",
                "label",
                "status"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "task",
                    "repo",
                    "manual_input",
                    "approval",
                    "artifact",
                    "external_system"
                  ]
                },
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "open",
                    "resolved"
                  ]
                }
              }
            }
          },
          "acceptance": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "verify": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
